<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NOC Operational Reports Engine - Teleglobal</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f4f6f9; margin: 0; padding: 20px; }
        .container { max-width: 1000px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .header-bar { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #e2e8f0; padding-bottom: 20px; margin-bottom: 25px; gap: 15px; flex-wrap: wrap; }
        h1 { color: #1e293b; margin: 0; font-size: 24px; font-weight: 700; }
        .nav-group { display: flex; gap: 10px; align-items: center; }
        .nav-link-btn { background: #2563eb; color: white; padding: 10px 18px; border-radius: 6px; font-weight: 600; font-size: 14px; border: none; text-decoration: none; cursor: pointer; }
        .nav-link-btn.alt { background: #475569; }
        .nav-link-btn:hover { opacity: 0.9; }
        
        .card { background: #f8fafc; border: 1px solid #e2e8f0; padding: 25px; border-radius: 6px; margin-bottom: 20px; }
        .form-group { margin-bottom: 18px; }
        label { display: block; font-weight: 600; margin-bottom: 8px; color: #475569; font-size: 14px; }
        input, select { width: 100%; padding: 11px; border: 1px solid #cbd5e1; border-radius: 4px; box-sizing: border-box; font-size: 14px; background-color: #fff; }
        .row { display: flex; gap: 15px; }
        .col { flex: 1; }
        .download-btn { background: #10b981; color: white; border: none; padding: 14px; width: 100%; cursor: pointer; border-radius: 6px; font-size: 16px; font-weight: bold; margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 2px 4px rgba(16, 185, 129, 0.2); }
        .download-btn:hover { background: #059669; }
        
        .specification-box { background: #f1f5f9; border-left: 4px solid #3b82f6; padding: 15px; border-radius: 0 6px 6px 0; font-size: 13px; color: #334155; margin-top: 15px; line-height: 1.5; }
        @media (max-width: 768px) { .row { flex-direction: column; gap: 0; } }
    </style>
</head>
<body>

<div class="container">

<!-- Locate this section inside your reports.html file (around line 38-43) and replace it with this: -->
<div class="header-bar">
    <div>
        <h1>Teleglobal NOC Operational Reports Hub</h1>
        <div style="color: #64748b; font-size: 14px; margin-top: 4px;">
            Authorized Operator: <strong style="color: #1e293b;">{% if user %}{{ user.full_name }}{% else %}NOC Operator{% endif %}</strong>
        </div>
    </div>
    <div class="nav-group">
        <a href="/" class="nav-link-btn alt">🏠 Back to Operations Dashboard</a>
    </div>
</div>

    <div class="card">
        <h3>Configure Export Parameters</h3>
        <form id="reportForm" onsubmit="triggerReportDownload(event)">
            
            <div class="form-group">
                <label>Select Core Report Model Category</label>
                <select id="report_type" onchange="updateSpecificationPreview()" required>
                    <option value="tickets" selected>1. Incident Tracking & Ticket Logs Report</option>
                    <option value="welcome_links">2. New Link Provisioning & Welcome Logs</option>
                    <option value="bandwidth_changes">3. Bandwidth Upgradation / Downgradion History</option>
                    <option value="link_terminations">4. Link Termination & Decommissioning Logs</option>
                </select>
            </div>

            <div class="row">
                <div class="form-group col">
                    <label>Start Date (Filter Window)</label>
                    <input type="date" id="start_date">
                </div>
                <div class="form-group col">
                    <label>End Date (Filter Window)</label>
                    <input type="date" id="end_date">
                </div>
            </div>

            <div class="form-group" id="teamFilterGroup">
                <label>Assigned Operational Team Filter</label>
                <select id="assigned_team">
                    <option value="All">-- All Teams Combined --</option>
                    <option value="NOC Team">NOC Team</option>
                    <option value="INFRA Team">INFRA Team</option>
                    <option value="Fiber vendor">Fiber vendor</option>
                    <option value="Upstream Team">Upstream Team</option>
                </select>
            </div>

            <div class="specification-box">
                <strong>📋 Expected Output Specifications:</strong>
                <div id="spec_text">Exports Ticket Identification numbers, circuit relational bindings, associated diagnostics schemas, active durations, system operators, and categorical statuses.</div>
            </div>

            <button type="submit" class="download-btn">
                <span>📥 Generate & Download Structured CSV Report</span>
            </button>
        </form>
    </div>
</div>

<script>
function updateSpecificationPreview() {
    const type = document.getElementById('report_type').value;
    const specText = document.getElementById('spec_text');
    const teamGroup = document.getElementById('teamFilterGroup');
    
    if (type === 'tickets') {
        teamGroup.style.display = 'block';
        specText.innerHTML = "Exports ticket identifiers, system circuit codes, client entities, diagnostics categories, assigned groups, runtime durations, opening operators, closing personnel, and logging metrics.";
    } else {
        teamGroup.style.display = 'none';
        if (type === 'welcome_links') {
            specText.innerHTML = "Exports inventory assignments, customer demographics data, allocation data links, contact indices, initial infrastructure handovers, and setup tracking records.";
        } else if (type === 'bandwidth_changes') {
            specText.innerHTML = "Extracts records detailing capacity upgrades/downgrades, requested specification parameters, validation statuses, tracking reference IDs, and timestamp arrays.";
        } else if (type === 'link_terminations') {
            specText.innerHTML = "Extracts legal decommissioning actions, shutdown validations, hardware retrieval status flags, customer exit reason descriptors, and technical approvals.";
        }
    }
}

async function triggerReportDownload(e) {
    e.preventDefault();
    
    const report_type = document.getElementById('report_type').value;
    const start_date = document.getElementById('start_date').value || null;
    const end_date = document.getElementById('end_date').value || null;
    const team = report_type === 'tickets' ? document.getElementById('assigned_team').value : null;

    try {
        const response = await fetch('/api/reports/download', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ report_type, start_date, end_date, team })
        });

        if (!response.ok) {
            const errorData = await response.json();
            alert(`Export Failed: ${errorData.detail || 'Unknown server error'}`);
            return;
        }

        const blob = await response.blob();
        
        const disposition = response.headers.get('Content-Disposition');
        let filename = `noc_report_${new Date().toISOString().slice(0,10)}.csv`;
        if (disposition && disposition.includes('filename=')) {
            filename = disposition.split('filename=')[1].replaceAll('"', '');
        }

        const downloadUrl = window.URL.createObjectURL(blob);
        const transientAnchor = document.createElement('a');
        transientAnchor.href = downloadUrl;
        transientAnchor.download = filename;
        
        document.body.appendChild(transientAnchor);
        transientAnchor.click();
        
        transientAnchor.remove();
        window.URL.revokeObjectURL(downloadUrl);

    } catch (error) {
        console.error("Transmission breakdown during CSV extraction:", error);
        alert("Critical network error occurred while generating your report.");
    }
}
document.addEventListener('DOMContentLoaded', updateSpecificationPreview);
</script>
</body>
</html>
