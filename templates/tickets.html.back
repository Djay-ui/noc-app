<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Managing Operational Tickets</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f4f6f9; margin: 0; padding: 20px; }
        .container { max-width: 1350px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .header-bar { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #e2e8f0; padding-bottom: 20px; margin-bottom: 25px; }
        h1 { color: #1e293b; margin: 0; font-size: 24px; font-weight: 700; }
        .back-btn { background: #475569; color: white; padding: 10px 16px; border-radius: 6px; font-weight: 600; font-size: 14px; text-decoration: none; }
        
        .kpi-row { display: flex; gap: 15px; margin-bottom: 25px; flex-wrap: wrap; }
        .kpi-card { flex: 1; min-width: 220px; padding: 20px; border-radius: 6px; border: 1px solid #e2e8f0; text-align: center; color: white; }
        .kpi-card.total { background: #3b82f6; }
        .kpi-card.open { background: #ef4444; }
        .kpi-card.monitoring { background: #f59e0b; }
        .kpi-card.closed { background: #10b981; }
        .kpi-val { font-size: 28px; font-weight: bold; margin-top: 5px; }

        input, select { padding: 10px; border: 1px solid #cbd5e1; border-radius: 4px; box-sizing: border-box; font-size: 14px; background-color: #fff; }
        .card { background: #f8fafc; border: 1px solid #e2e8f0; padding: 20px; border-radius: 6px; margin-bottom: 20px; }
        .export-btn { background: #4f46e5; color: white; border: none; padding: 0 20px; cursor: pointer; border-radius: 4px; font-weight: bold; }
        .export-btn:hover { background: #4338ca; }
        
        table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 10px; }
        th, td { padding: 10px; border: 1px solid #cbd5e1; text-align: left; }
        th { background: #e2e8f0; color: #334155; }
        .patch-btn { background: #2563eb; color: white; border: none; padding: 6px 12px; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 12px; }
        .patch-btn:hover { background: #1d4ed8; }
        .patch-btn:disabled { background: #cbd5e1; color: #94a3b8; cursor: not-allowed; }
        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: 600; margin-bottom: 5px; color: #475569; }
    </style>
</head>
<body>

<div class="container">
    <div class="header-bar">
        <div>
            <h1>Managing Operational Tickets</h1>
            <div style="color: #64748b; font-size: 14px; margin-top: 4px;">Role Level: <strong style="color: #2563eb; text-transform: uppercase;">{{ user.role }}</strong></div>
        </div>
        <a href="/" class="back-btn">← Back to Operations Desk</a>
    </div>

    <div class="kpi-row">
        <div class="kpi-card total"><div>Total Displayed</div><div class="kpi-val" id="kpi_total">0</div></div>
        <div class="kpi-card open"><div>Active Alarms (Open)</div><div class="kpi-val" id="kpi_open">0</div></div>
        <div class="kpi-card monitoring"><div>In Monitoring</div><div class="kpi-val" id="kpi_monitor">0</div></div>
        <div class="kpi-card closed"><div>Resolved Tickets</div><div class="kpi-val" id="kpi_closed">0</div></div>
    </div>

    <div class="card">
        <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; justify-content:space-between;">
            <div style="display:flex; gap:10px; flex-wrap:wrap; flex:1;">
                <input type="text" id="filter_search" onkeyup="refreshLogs()" placeholder="🔍 Search Ticket ID, Circuit ID..." style="width:280px; height:40px;">
                <select id="filter_status" onchange="refreshLogs()" style="width:160px; height:40px;">
                    <option value="">All Statuses</option>
                    <option value="Open">Open</option>
                    <option value="In Monitoring">In Monitoring</option>
                    <option value="Closed">Closed</option>
                </select>
                <select id="filter_limit" onchange="refreshLogs()" style="width:140px; height:40px;">
                    <option value="10">Show Last 10</option>
                    <option value="20">Show Last 20</option>
                    <option value="50">Show Last 50</option>
                </select>
            </div>
            
            <div style="display:flex; gap:10px;">
                <select id="filter_date_range" style="width:180px; height:40px;">
                    <option value="all">All Available History</option>
                    <option value="1_day">Last Day (24 Hours)</option>
                    <option value="3_days">Last 3 Days</option>
                    <option value="1_week">Last 1 Week</option>
                    <option value="1_month">Last 1 Month</option>
                </select>
                <button onclick="downloadCSVReport()" class="export-btn" style="height:40px;">📥 Download Export Matrix</button>
            </div>
        </div>

        <div style="overflow-x:auto; margin-top:20px;">
            <table>
                <thead>
                    <tr>
                        <th>Ticket #</th>
                        <th>Circuit ID</th>
                        <th>Alarm Subject</th>
                        <th>Assigned Operator Team</th>
                        <th>Open BY</th>
                        <th>Closed BY</th>
                        <th>Status</th>
                        <th>Opened Time</th>
                        <th>Closed Time</th>
                        <th>Duration</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="logTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

<div id="statusModal" style="display:none; position:fixed; z-index:9999; left:0; top:0; width:100%; height:100%; background:rgba(0,0,0,0.4); justify-content:center; align-items:center;">
    <div class="card" style="background:white; width:400px; padding:25px; border-radius:8px; box-shadow:0 4px 10px rgba(0,0,0,0.15);">
        <h4 style="margin-top:0; font-size:16px;">Modify Ticket Operational Status</h4>
        <input type="hidden" id="modal_ticket_id">
        <div class="form-group">
            <label>Target Status State</label>
            <select id="modal_status" style="width:100%;">
                <option value="Open">Open</option>
                <option value="In Monitoring">In Monitoring</option>
                <option value="Closed">Closed</option>
            </select>
        </div>
        <div class="form-group">
            <label>Actioning Authenticated User</label>
            <input type="text" value="{{ user.full_name }}" readonly style="background:#e2e8f0; color:#475569; font-weight:bold;">
        </div>

        <div style="margin-top: 15px; border-top: 1px solid #e2e8f0; padding-top: 15px;">
            <label style="display: block; font-size: 14px; font-weight: 600; color: #475569; margin-bottom: 6px;">
                Engineering Update Remarks / Closure Notes
            </label>
            <textarea id="modalRemarkNote" rows="3" 
              placeholder="Provide status update details (Optional)..." 
              style="width: 100%; border: 1px solid #cbd5e1; border-radius: 4px; padding: 10px; font-size: 13px; font-family: inherit; box-sizing: border-box; resize: vertical;"></textarea>
        </div>

        <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:20px;">
            <button type="button" onclick="closeModal()" style="background:#cbd5e1; color:#334155; border:none; padding:8px 15px; border-radius:4px; font-weight:bold; cursor:pointer;">Cancel</button>
            <button type="button" onclick="commitStatusUpdate()" style="background:#10b981; color:white; border:none; padding:8px 15px; border-radius:4px; font-weight:bold; cursor:pointer;">Update Record</button>
        </div>
    </div>
</div>

<script>
const userRole = "{{ user.role }}";

function openStatusModal(id, currentStatus) {
    if(userRole !== 'admin') {
        alert('Access Denied: Only users with Admin clearance can modify active states.');
        return;
    }
    document.getElementById('modal_ticket_id').value = id;
    document.getElementById('modal_status').value = currentStatus;
    document.getElementById('modalRemarkNote').value = '';
    document.getElementById('statusModal').style.display = 'flex';
}

function closeModal() { document.getElementById('statusModal').style.display = 'none'; }

async function commitStatusUpdate() {
    const ticketId = document.getElementById('modal_ticket_id').value;
    const status = document.getElementById('modal_status').value;
    const remarkNote = document.getElementById('modalRemarkNote').value.trim();

    try {
        const res = await fetch('/api/ticket/update-status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                ticket_id: parseInt(ticketId), 
                status: status, 
                remark_note: remarkNote
            })
        });
        
        if(res.ok) {
            closeModal();
            refreshLogs();
        } else { 
            // Extracts explicit exception details from FastAPI background handlers
            const errorData = await res.json().catch(() => ({}));
            throw new Error(errorData.detail || 'Failed to patch record table status.'); 
        }
    } catch(e) { 
        alert('Operational Error: ' + e.message); 
    }
}

function downloadCSVReport() {
    const search = document.getElementById('filter_search').value;
    const status = document.getElementById('filter_status').value;
    const dateRange = document.getElementById('filter_date_range').value;
    window.location.href = `/api/reports/download?circuit_id=${encodeURIComponent(search)}&status=${status}&date_range=${dateRange}`;
}

async function refreshLogs() {
    try {
        const search = document.getElementById('filter_search').value;
        const status = document.getElementById('filter_status').value;
        const limit = document.getElementById('filter_limit').value;
        
        const res = await fetch(`/api/tickets/recent?limit=${limit}&search=${encodeURIComponent(search)}&status=${status}`);
        const tickets = await res.json();
        const body = document.getElementById('logTableBody');
        body.innerHTML = '';
        
        let openCount = 0, monitorCount = 0, closedCount = 0;
        
        tickets.forEach(t => {
            if (t.status === 'Open') openCount++;
            else if (t.status === 'In Monitoring') monitorCount++;
            else if (t.status === 'Closed') closedCount++;

            const durationText = t.status === 'Closed' ? `${t.resolution_minutes} Mins` : '--';
            const actionButtonAttr = (userRole === 'admin') ? '' : 'disabled title="Requires Admin Role"';

            body.innerHTML += `
            <tr>
                <td style="font-weight:bold;">${t.ticket_id}</td>
                <td style="font-family:monospace;">${t.circuit_id}</td>
                <td>${t.issue_category}</td>
                <td style="font-weight:600; color:#475569;">${t.assigned_team}</td>
                <td>${t.open_by_name}</td>
                <td>${t.closed_by_name}</td>
                <td><span style="padding:3px 8px; font-size:11px; border-radius:10px; font-weight:bold; background:${t.status==='Closed'?'#d1fae5;color:#065f46':t.status==='In Monitoring'?'#fef3c7;color:#d97706':'#fee2e2;color:#991b1b'}">${t.status}</span></td>
                <td style="color:#64748b;">${t.timestamp}</td>
                <td style="color:#64748b;">${t.closed_timestamp}</td>
                <td style="font-weight:bold; color:#1e293b;">${durationText}</td>
                <td><button type="button" class="patch-btn" ${actionButtonAttr} onclick="openStatusModal(${t.raw_ticket_id}, '${t.status}')">Modify State</button></td>
            </tr>`;
        });

        document.getElementById('kpi_total').textContent = tickets.length;
        document.getElementById('kpi_open').textContent = openCount;
        document.getElementById('kpi_monitor').textContent = monitorCount;
        document.getElementById('kpi_closed').textContent = closedCount;

    } catch(err) { console.error('Failed to pull system event streams:', err); }
}
window.addEventListener('DOMContentLoaded', refreshLogs);
</script>
</body>
</html>
